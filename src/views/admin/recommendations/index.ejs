<%- include('../../partials/admin-head') %>

<div class="content-header">
  <h2>Manage Recommendations</h2>
</div>

<% if (typeof success !== 'undefined' && success) { %>
  <div class="alert alert-success"><%= success %></div>
<% } %>

<!-- Pending Recommendations Panel -->
<div class="panel" style="margin-bottom: 32px;">
  <div class="panel-header">
    <h2>Pending Recommendations (Requires Approval)</h2>
  </div>
  <div class="panel-body">
    <% if (pending.length > 0) { %>
      <div style="display:flex; flex-direction:column; gap:20px;">
        <% pending.forEach(rec => { %>
          <div style="background:rgba(255,255,255,0.02); border:1px solid var(--admin-border); border-radius:var(--admin-radius); padding:20px;">
            <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px; margin-bottom:12px;">
              <div style="display:flex; align-items:center; gap:12px;">
                <div style="width: 40px; height: 40px; border-radius:50%; overflow:hidden; background:rgba(255,255,255,0.05); display:flex; align-items:center; justify-content:center;">
                  <% if (rec.avatar_url) { %>
                    <img src="<%= rec.avatar_url %>" alt="<%= rec.username %>" style="width:100%; height:100%; object-fit:cover;">
                  <% } else { %>
                    <span style="font-weight:700; color:var(--admin-accent);"><%= rec.username.charAt(0).toUpperCase() %></span>
                  <% } %>
                </div>
                <div>
                  <h4 style="margin:0; font-size:0.9rem;">Written by @<%= rec.username %></h4>
                  <p style="margin:0; font-size:0.75rem; color:var(--admin-text-secondary);"><%= rec.site_title || 'Developer Profile' %></p>
                </div>
              </div>
              <div style="display:flex; gap:8px;">
                <form method="POST" action="/admin/recommendations/<%= rec.id %>/approve">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="btn btn-xs btn-primary">Approve & Show</button>
                </form>
                <form method="POST" action="/admin/recommendations/<%= rec.id %>/delete">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="btn btn-xs btn-outline" style="color:#ff7675;">Decline</button>
                </form>
              </div>
            </div>
            <div style="background:rgba(0,0,0,0.2); border-left: 3px solid var(--admin-accent); padding:12px 16px; border-radius:4px; font-style:italic; font-size:0.9rem; color:var(--admin-text-secondary); line-height:1.5;">
              "<%= rec.content %>"
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p style="color:var(--admin-text-muted); text-align:center; padding:16px;">No recommendations pending approval.</p>
    <% } %>
  </div>
</div>

<!-- Active/Approved Recommendations Panel -->
<div class="panel">
  <div class="panel-header">
    <h2>Approved Recommendations on Your Portfolio</h2>
  </div>
  <div class="panel-body">
    <% if (approved.length > 0) { %>
      <div style="display:flex; flex-direction:column; gap:20px;">
        <% approved.forEach(rec => { %>
          <div style="background:rgba(255,255,255,0.02); border:1px solid var(--admin-border); border-radius:var(--admin-radius); padding:20px;">
            <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px; margin-bottom:12px;">
              <div style="display:flex; align-items:center; gap:12px;">
                <div style="width: 40px; height: 40px; border-radius:50%; overflow:hidden; background:rgba(255,255,255,0.05); display:flex; align-items:center; justify-content:center;">
                  <% if (rec.avatar_url) { %>
                    <img src="<%= rec.avatar_url %>" alt="<%= rec.username %>" style="width:100%; height:100%; object-fit:cover;">
                  <% } else { %>
                    <span style="font-weight:700; color:var(--admin-accent);"><%= rec.username.charAt(0).toUpperCase() %></span>
                  <% } %>
                </div>
                <div>
                  <h4 style="margin:0; font-size:0.9rem;">Showcased from @<%= rec.username %></h4>
                  <p style="margin:0; font-size:0.75rem; color:var(--admin-text-secondary);"><%= rec.site_title || 'Developer Profile' %></p>
                </div>
              </div>
              <form method="POST" action="/admin/recommendations/<%= rec.id %>/delete">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="btn btn-xs btn-danger" style="background:#ee5253; border:none; padding:4px 8px; border-radius:4px; font-size:0.75rem; cursor:pointer;">Remove</button>
              </form>
            </div>
            <div style="background:rgba(0,0,0,0.2); border-left: 3px solid var(--admin-accent); padding:12px 16px; border-radius:4px; font-style:italic; font-size:0.9rem; color:var(--admin-text-secondary); line-height:1.5;">
              "<%= rec.content %>"
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p style="color:var(--admin-text-muted); text-align:center; padding:16px;">No recommendations displayed on your public page yet.</p>
    <% } %>
  </div>
</div>

<%- include('../../partials/admin-tail') %>
