<%- include('../../partials/admin-head') %>

<div class="content-header">
  <h2><%= blog ? 'Edit Blog Post' : 'New Blog Post' %></h2>
  <a href="/admin/blogs" class="btn btn-outline btn-sm">← Back</a>
</div>

<% if (error) { %>
<div class="alert alert-error"><%= error %></div>
<% } %>

<form method="POST" action="/admin/blogs<%= blog && blog.id ? '/' + blog.id : '' %>" enctype="multipart/form-data" class="admin-form">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <div class="form-group">
    <label for="title" class="form-label">Title *</label>
    <input type="text" id="title" name="title" class="form-input" required value="<%= blog ? (blog.title || '') : '' %>">
  </div>

  <div class="form-group">
    <label for="excerpt" class="form-label">Excerpt</label>
    <textarea id="excerpt" name="excerpt" class="form-input" rows="2" placeholder="Brief summary for the blog listing..."><%= blog ? (blog.excerpt || '') : '' %></textarea>
  </div>

  <div class="form-group">
    <label for="content" class="form-label">Content (Markdown) *</label>
    <textarea id="content" name="content" class="form-input form-textarea form-textarea--large" rows="16" required><%= blog ? (blog.content || '') : '' %></textarea>
  </div>

  <div class="form-group">
    <label for="tags" class="form-label">Tags (comma-separated)</label>
    <input type="text" id="tags" name="tags" class="form-input" value="<%= blog ? (blog.tags_str || '') : '' %>" placeholder="JavaScript, Tutorial, Web Dev">
  </div>

  <div class="form-group">
    <label for="cover_image" class="form-label">Cover Image</label>
    <input type="file" id="cover_image" name="cover_image" class="form-input-file" accept="image/*">
    <% if (blog && blog.cover_image) { %>
    <div class="current-image">
      <img src="<%= blog.cover_image %>" alt="Current cover" style="max-width: 300px; margin-top: 8px; border-radius: 8px;">
    </div>
    <% } %>
  </div>

  <div class="form-group">
    <label class="form-checkbox">
      <input type="checkbox" name="published" value="1" <%= blog && blog.published ? 'checked' : '' %>>
      <span>Published</span>
    </label>
  </div>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary"><%= blog ? 'Update Post' : 'Create Post' %></button>
    <a href="/admin/blogs" class="btn btn-outline">Cancel</a>
  </div>
</form>

<%- include('../../partials/admin-tail') %>
