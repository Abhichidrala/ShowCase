<%- include('../../partials/admin-head') %>

<div class="content-header">
  <h2>Manage Connections</h2>
</div>

<% if (typeof success !== 'undefined' && success) { %>
  <div class="alert alert-success"><%= success %></div>
<% } %>

<!-- Pending Requests Panel -->
<div class="panel" style="margin-bottom: 32px;">
  <div class="panel-header">
    <h2>Incoming Connection Requests</h2>
  </div>
  <div class="panel-body">
    <% if (pendingRequests.length > 0) { %>
      <div style="display:flex; flex-direction:column; gap:16px;">
        <% pendingRequests.forEach(req => { %>
          <div style="display:flex; justify-content:space-between; align-items:center; background:rgba(255,255,255,0.02); border:1px solid var(--admin-border); border-radius:var(--admin-radius); padding:16px; flex-wrap:wrap; gap:12px;">
            <div style="display:flex; align-items:center; gap:16px;">
              <div style="width: 45px; height: 45px; border-radius:50%; overflow:hidden; background:rgba(255,255,255,0.05); border:1px solid var(--admin-border); display:flex; align-items:center; justify-content:center;">
                <% if (req.avatar_url) { %>
                  <img src="<%= req.avatar_url %>" alt="<%= req.username %>" style="width:100%; height:100%; object-fit:cover;">
                <% } else { %>
                  <span style="font-weight:700; color:var(--admin-accent);"><%= req.username.charAt(0).toUpperCase() %></span>
                <% } %>
              </div>
              <div>
                <h4 style="margin:0; font-size:0.95rem;">@<%= req.username %></h4>
                <p style="margin:0; font-size:0.8rem; color:var(--admin-text-secondary);"><%= req.site_title || 'Showcase Profile' %></p>
              </div>
            </div>
            <div style="display:flex; gap:10px;">
              <form method="POST" action="/admin/connections/<%= req.id %>/accept">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="btn btn-xs btn-primary">Accept</button>
              </form>
              <form method="POST" action="/admin/connections/<%= req.id %>/reject">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="btn btn-xs btn-outline">Decline</button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p style="color:var(--admin-text-muted); text-align:center; padding:16px;">No pending connection requests.</p>
    <% } %>
  </div>
</div>

<!-- Active Connections Panel -->
<div class="panel">
  <div class="panel-header">
    <h2>Connected Developers</h2>
  </div>
  <div class="panel-body">
    <% if (connections.length > 0) { %>
      <div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px;">
        <% connections.forEach(conn => { %>
          <div style="display:flex; justify-content:space-between; align-items:center; background:rgba(255,255,255,0.02); border:1px solid var(--admin-border); border-radius:var(--admin-radius); padding:16px;">
            <div style="display:flex; align-items:center; gap:12px;">
              <div style="width: 40px; height: 40px; border-radius:50%; overflow:hidden; background:rgba(255,255,255,0.05); display:flex; align-items:center; justify-content:center;">
                <% if (conn.avatar_url) { %>
                  <img src="<%= conn.avatar_url %>" alt="<%= conn.username %>" style="width:100%; height:100%; object-fit:cover;">
                <% } else { %>
                  <span style="font-weight:700; color:var(--admin-accent);"><%= conn.username.charAt(0).toUpperCase() %></span>
                <% } %>
              </div>
              <div style="max-width:140px;">
                <h4 style="margin:0; font-size:0.9rem; white-space:nowrap; text-overflow:ellipsis; overflow:hidden;">@<%= conn.username %></h4>
                <p style="margin:0; font-size:0.75rem; color:var(--admin-text-secondary); white-space:nowrap; text-overflow:ellipsis; overflow:hidden;"><%= conn.site_title || 'Showcase Profile' %></p>
              </div>
            </div>
            <div style="display:flex; flex-direction:column; gap:6px;">
              <a href="/<%= conn.username %>" target="_blank" class="btn btn-xs btn-outline" style="text-align:center; font-size:0.75rem; padding:4px 8px;">View</a>
              <form method="POST" action="/admin/connections/<%= conn.id %>/reject">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="btn btn-xs btn-danger" style="background:#ee5253; border:none; padding:4px 8px; border-radius:4px; font-size:0.75rem; width:100%; cursor:pointer;">Remove</button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p style="color:var(--admin-text-muted); text-align:center; padding:16px;">No active connections. Explore the <a href="/discover" style="color:var(--admin-accent);">Creator Directory</a> to find peers!</p>
    <% } %>
  </div>
</div>

<%- include('../../partials/admin-tail') %>
