<%- include('../partials/admin-head') %>

<div class="dashboard-grid">
  <div class="stat-card stat-card--accent">
    <div class="stat-card-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
    </div>
    <div class="stat-card-info">
      <span class="stat-card-number"><%= stats.projects %></span>
      <span class="stat-card-label">Projects</span>
    </div>
  </div>
  <div class="stat-card stat-card--green">
    <div class="stat-card-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
    </div>
    <div class="stat-card-info">
      <span class="stat-card-number"><%= stats.skills %></span>
      <span class="stat-card-label">Skills</span>
    </div>
  </div>
  <div class="stat-card stat-card--purple">
    <div class="stat-card-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
    </div>
    <div class="stat-card-info">
      <span class="stat-card-number"><%= stats.experience %></span>
      <span class="stat-card-label">Experience</span>
    </div>
  </div>
  <div class="stat-card stat-card--orange">
    <div class="stat-card-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
    </div>
    <div class="stat-card-info">
      <span class="stat-card-number"><%= stats.certificates %></span>
      <span class="stat-card-label">Certificates</span>
    </div>
  </div>
  <div class="stat-card stat-card--cyan">
    <div class="stat-card-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
    </div>
    <div class="stat-card-info">
      <span class="stat-card-number"><%= stats.publishedBlogs %>/<%= stats.blogs %></span>
      <span class="stat-card-label">Blog Posts (Published/Total)</span>
    </div>
  </div>
  
  <!-- Connections stat -->
  <div class="stat-card stat-card--green" style="border-color: var(--admin-accent);">
    <div class="stat-card-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
    </div>
    <div class="stat-card-info">
      <span class="stat-card-number"><%= stats.connections %></span>
      <span class="stat-card-label">Active Connections (<%= stats.pendingConnections %> Pending)</span>
    </div>
  </div>
</div>

<div class="dashboard-panels" style="display:flex; flex-direction:column; gap:24px;">
  <!-- Pending Reviews alerts -->
  <% if (stats.pendingConnections > 0 || stats.pendingRecommendations > 0) { %>
    <div class="panel" style="border-color:#ff9f43; background:rgba(255,159,67,0.02);">
      <div class="panel-header" style="border-color:rgba(255,159,67,0.15);">
        <h2 style="color:#ff9f43; display:flex; align-items:center; gap:8px;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          Action Items Required
        </h2>
      </div>
      <div class="panel-body" style="display:flex; flex-direction:column; gap:10px;">
        <% if (stats.pendingConnections > 0) { %>
          <div style="display:flex; justify-content:space-between; align-items:center;">
            <span>You have <strong><%= stats.pendingConnections %></strong> incoming connection requests waiting.</span>
            <a href="/admin/connections" class="btn btn-sm btn-outline" style="border-color:#ff9f43; color:#ff9f43;">Review Requests</a>
          </div>
        <% } %>
        <% if (stats.pendingRecommendations > 0) { %>
          <div style="display:flex; justify-content:space-between; align-items:center; margin-top: 8px;">
            <span>You have <strong><%= stats.pendingRecommendations %></strong> endorsements/recommendations waiting approval.</span>
            <a href="/admin/recommendations" class="btn btn-sm btn-outline" style="border-color:#ff9f43; color:#ff9f43;">Review Recommendations</a>
          </div>
        <% } %>
      </div>
    </div>
  <% } %>

  <div class="panel">
    <div class="panel-header"><h2>Quick Actions</h2></div>
    <div class="panel-body">
      <div class="quick-actions">
        <a href="/admin/projects/new" class="quick-action-btn">+ New Project</a>
        <a href="/admin/blogs/new" class="quick-action-btn">+ New Blog Post</a>
        <a href="/admin/skills/new" class="quick-action-btn">+ Add Skill</a>
        <a href="/admin/experience/new" class="quick-action-btn">+ Add Experience</a>
        <a href="/admin/education/new" class="quick-action-btn">+ Add Education</a>
        <a href="/admin/certificates/new" class="quick-action-btn">+ Add Certificate</a>
        <a href="/admin/gallery" class="quick-action-btn">+ Gallery Upload</a>
        <a href="/admin/settings" class="quick-action-btn">⚙ Settings</a>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/admin-tail') %>
