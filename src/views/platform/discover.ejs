<%- include('../partials/head') %>

<section class="section" style="padding-top:140px; min-height:100vh;">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-tag">Talent Search</span>
      <h2 class="section-title">Developer Directory</h2>
      <p class="section-subtitle">Search and connect with creative developers across the network</p>
    </div>

    <!-- Search Form -->
    <div class="reveal" style="max-width: 600px; margin: 0 auto 40px; background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius-lg); padding: 24px;">
      <form action="/discover" method="GET" style="display:flex; flex-direction:column; gap:16px;">
        <div style="display:flex; gap:10px; flex-wrap:wrap;">
          <input type="text" name="q" value="<%= query %>" placeholder="Search by name, username or bio..." style="flex:1; padding: 12px 16px; background: rgba(0,0,0,0.4); border: 1px solid var(--border-color); border-radius: var(--radius); color: var(--text-primary); font-family:inherit;" autofocus>
          <button type="submit" class="btn btn-primary">Search</button>
        </div>
        <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
          <span style="font-size:0.85rem; color:var(--text-secondary);">Filter by Skill:</span>
          <input type="text" name="skill" value="<%= filterSkill %>" placeholder="e.g. React" style="padding: 6px 12px; background: rgba(0,0,0,0.4); border: 1px solid var(--border-color); border-radius: var(--radius); color: var(--text-primary); font-size:0.85rem; max-width:150px;">
          <% if (query || filterSkill) { %>
            <a href="/discover" style="font-size:0.85rem; color:var(--accent);">Clear Filters</a>
          <% } %>
        </div>
      </form>
    </div>

    <!-- Results Grid -->
    <% if (users.length > 0) { %>
      <div class="projects-grid" style="grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 24px;">
        <% users.forEach((dev, index) => { %>
          <article class="project-card reveal" style="--delay: <%= index * 0.05 %>s; padding: 24px; display:flex; flex-direction:column; justify-content:space-between; background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius-lg); transition: all var(--transition);">
            <div>
              <div style="display:flex; align-items:center; gap:16px; margin-bottom:16px;">
                <div style="width: 50px; height: 50px; border-radius: 50%; overflow:hidden; border: 2px solid var(--border-color); background: rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: center;">
                  <% if (dev.avatar_url) { %>
                    <img src="<%= dev.avatar_url %>" alt="<%= dev.username %>" style="width:100%; height:100%; object-fit:cover;">
                  <% } else { %>
                    <span style="font-size: 1.3rem; font-weight:700; color: var(--accent);"><%= dev.username.charAt(0).toUpperCase() %></span>
                  <% } %>
                </div>
                <div>
                  <h3 style="font-size:1.1rem; font-weight:700; margin:0;"><%= dev.site_title || dev.username %></h3>
                  <p style="font-size:0.8rem; color:var(--text-secondary); margin:0;">@<%= dev.username %></p>
                </div>
              </div>
              <p style="font-size:0.85rem; color:var(--text-secondary); margin-bottom:16px; min-height: 40px; line-height: 1.5;">
                <%= dev.hero_subtitle || 'Developer Profile' %>
              </p>
              <% if (dev.about_bio) { %>
                <p style="font-size:0.8rem; color:var(--text-muted); line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom:16px;">
                  <%= dev.about_bio %>
                </p>
              <% } %>
            </div>
            <div>
              <a href="/<%= dev.username %>" class="btn btn-sm btn-outline" style="width:100%; justify-content:center;">View Showcase</a>
            </div>
          </article>
        <% }) %>
      </div>
    <% else { %>
      <div class="reveal" style="text-align:center; padding:60px; border:1px dashed var(--border-color); border-radius:var(--radius-lg); max-width:500px; margin:0 auto;">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom:16px; color:var(--text-muted);"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <h3 style="margin-bottom:8px;">No matching portfolios found</h3>
        <p style="color:var(--text-muted); font-size:0.9rem; margin-bottom:20px;">Try searching for a different keyword or removing active skill filters.</p>
        <a href="/discover" class="btn btn-sm btn-primary">Refresh Directory</a>
      </div>
    <% } %>
  </div>
</section>

<%- include('../partials/tail') %>
