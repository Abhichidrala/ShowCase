<%- include('../partials/head') %>

<!-- Platform Hero Section -->
<section class="hero" id="hero">
  <div class="hero-bg">
    <div class="hero-orb hero-orb--1" style="display:block; background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%); width:600px; height:600px; position:absolute; top:-200px; left:20%; filter:blur(80px); animation: float 15s infinite;"></div>
    <div class="hero-grid"></div>
  </div>
  <div class="container hero-content" style="z-index: 2;">
    <div class="hero-badge reveal">
      <span class="badge-dot" style="background: var(--accent);"></span>
      Discover & Connect with Top Developers
    </div>
    <h1 class="hero-title reveal">
      Create Your Premium Dynamic Portfolio
    </h1>
    <p class="hero-subtitle reveal">
      <span class="typing-text" data-text="Showcase Projects. Endorse Skills. Connect Globally."></span><span class="typing-cursor">|</span>
    </p>
    <p class="hero-description reveal" style="max-width: 650px;">
      Build an interactive developer profile using our premium glassmorphic dark-mode templates. Connect with colleagues, write blogs, gather skill endorsements, and manage everything from your personal dashboard.
    </p>
    <div class="hero-actions reveal">
      <% if (user) { %>
        <a href="/admin" class="btn btn-primary btn-lg">
          Go to Dashboard
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="/discover" class="btn btn-outline btn-lg">Explore Creators</a>
      <% } else { %>
        <a href="/register" class="btn btn-primary btn-lg">
          Get Started Free
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="/login" class="btn btn-outline btn-lg">Sign In</a>
      <% } %>
    </div>
    <div class="hero-stats reveal">
      <div class="stat">
        <span class="stat-number" data-count="<%= usersCount %>">0</span>
        <span class="stat-label">Creators</span>
      </div>
      <div class="stat">
        <span class="stat-number" data-count="<%= projectsCount %>">0</span>
        <span class="stat-label">Projects</span>
      </div>
    </div>
  </div>
</section>

<!-- Featured Developers Grid -->
<section class="section" id="featured-developers" style="padding-top: 40px;">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-tag">Talent Directory</span>
      <h2 class="section-title">Featured Portfolios</h2>
      <p class="section-subtitle">Stunning profiles crafted using our showcase layout</p>
    </div>
    <div class="projects-grid" style="grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 24px;">
      <% featuredDevs.forEach((dev, index) => { %>
        <article class="project-card reveal" style="--delay: <%= index * 0.1 %>s; padding: 24px; display:flex; flex-direction:column; justify-content:space-between; background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius-lg); transition: all var(--transition);">
          <div>
            <div style="display:flex; align-items:center; gap:16px; margin-bottom:16px;">
              <div style="width: 60px; height: 60px; border-radius: 50%; overflow:hidden; border: 2px solid var(--border-color); background: rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: center;">
                <% if (dev.avatar_url) { %>
                  <img src="<%= dev.avatar_url %>" alt="<%= dev.username %>" style="width:100%; height:100%; object-fit:cover;">
                <% } else { %>
                  <span style="font-size: 1.5rem; font-weight:700; color: var(--accent);"><%= dev.username.charAt(0).toUpperCase() %></span>
                <% } %>
              </div>
              <div>
                <h3 style="font-size:1.15rem; font-weight:700; margin:0;"><%= dev.site_title || dev.username %></h3>
                <p style="font-size:0.85rem; color:var(--text-secondary); margin:0;">@<%= dev.username %></p>
              </div>
            </div>
            <p style="font-size:0.9rem; color:var(--text-secondary); margin-bottom:16px; min-height: 50px; line-height: 1.5;">
              <%= dev.hero_subtitle || 'Software Engineer' %>
            </p>
          </div>
          <div>
            <a href="/<%= dev.username %>" class="btn btn-sm btn-outline" style="width:100%; justify-content:center;">View Portfolio</a>
          </div>
        </article>
      <% }) %>
    </div>
    <div class="section-cta reveal" style="margin-top:40px;">
      <a href="/discover" class="btn btn-outline">
        View All Portfolios
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </div>
</section>

<!-- Global Network Activity Feed (LinkedIn-style) -->
<section class="section section--dark" id="activity-feed">
  <div class="container" style="max-width: 800px;">
    <div class="section-header reveal">
      <span class="section-tag">Social Feed</span>
      <h2 class="section-title">Developer Feed</h2>
      <p class="section-subtitle">Real-time updates from creators across the network</p>
    </div>
    
    <% if (activities.length > 0) { %>
      <div style="display:flex; flex-direction:column; gap:20px; margin-top:30px;">
        <% activities.forEach((activity, index) => { %>
          <div class="reveal" style="--delay: <%= index * 0.05 %>s; background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: var(--radius); padding: 20px; display:flex; gap:16px; align-items:flex-start;">
            <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--border-color); display:flex; align-items:center; justify-content:center; font-weight:700; color:var(--accent);">
              <%= activity.username.charAt(0).toUpperCase() %>
            </div>
            <div style="flex:1;">
              <div style="display:flex; justify-content:between; align-items:baseline; flex-wrap:wrap; margin-bottom:4px;">
                <strong style="font-size:0.95rem; margin-right:8px;"><a href="/<%= activity.username %>" style="color:var(--text-primary);">@<%= activity.username %></a></strong>
                <span style="font-size:0.75rem; color:var(--text-muted);"><%= new Date(activity.created_at).toLocaleDateString('en-US', {month: 'short', day: 'numeric', hour: '2-digit', minute:'2-digit'}) %></span>
              </div>
              <p style="font-size:0.9rem; color:var(--text-secondary); margin:0;"><%= activity.content %></p>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="reveal" style="text-align:center; padding:40px; border:1px dashed var(--border-color); border-radius:var(--radius); color:var(--text-muted);">
        No recent updates in the network feed yet.
      </div>
    <% } %>
  </div>
</section>

<%- include('../partials/tail') %>
