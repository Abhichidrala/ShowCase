<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Password | Showcase</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css?v=3">
  <meta name="robots" content="noindex, nofollow">
</head>
<body class="login-body">
  <div class="login-container">
    <div class="login-card">
      <div class="login-header">
        <div class="login-logo">&lt;/&gt;</div>
        <h1>Reset Password</h1>
        <p>Enter your email to request a reset link</p>
      </div>

      <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert alert-success" style="background: rgba(255,255,255,0.05); color: #ffffff; border: 1px solid rgba(255,255,255,0.2); padding: 12px; border-radius: 8px; margin-bottom: 20px; font-size: 0.85rem; display: flex; align-items: center; gap: 8px;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        <%= success %>
      </div>
      <% } %>

      <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error" role="alert" style="background: rgba(255,255,255,0.05); color: #ffffff; border: 1px solid rgba(255,255,255,0.2); padding: 12px; border-radius: 8px; margin-bottom: 20px; font-size: 0.85rem; display: flex; align-items: center; gap: 8px;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <%= error %>
      </div>
      <% } %>

      <% if (!success) { %>
      <form method="POST" action="/forgot-password" class="login-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group">
          <label for="email" class="form-label">Email Address</label>
          <input type="email" id="email" name="email" class="form-input" required autofocus placeholder="Enter account email">
        </div>
        <button type="submit" class="btn btn-primary btn-block" style="width:100%; display:flex; justify-content:center; gap:8px;">
          Send Reset Link
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </form>
      <% } %>
      
      <div style="margin-top: 24px; text-align: center; font-size: 0.85rem;">
        <a href="/login" style="color: var(--admin-accent); text-decoration: none; font-weight: 500;">Back to login</a>
      </div>
    </div>
  </div>
</body>
</html>
