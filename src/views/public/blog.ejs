<%- include('../partials/head') %>

<section class="page-header">
  <div class="container">
    <span class="section-tag reveal">Blog</span>
    <h1 class="page-title reveal">Articles & Insights</h1>
    <p class="page-subtitle reveal">Thoughts on code, design, and development</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <% if (blogs.length > 0) { %>
    <div class="blog-search reveal">
      <div class="search-wrapper">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" id="blogSearch" placeholder="Search articles..." class="search-input" aria-label="Search articles">
      </div>
    </div>
    <div class="blog-grid blog-grid--full" id="blogList">
      <% blogs.forEach((blog, index) => { %>
      <article class="blog-card reveal" data-title="<%= blog.title.toLowerCase() %>" data-tags="<%= blog.tags %>" style="--delay: <%= (index % 6) * 0.08 %>s">
        <% if (blog.cover_image) { %>
        <div class="blog-card-image">
          <img src="<%= blog.cover_image %>" alt="<%= blog.title %>" loading="lazy">
        </div>
        <% } %>
        <div class="blog-card-content">
          <div class="blog-card-meta">
            <time datetime="<%= blog.created_at %>"><%= new Date(blog.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></time>
            <span class="meta-dot">·</span>
            <span><%= blog.reading_time %> min read</span>
          </div>
          <h2 class="blog-card-title"><a href="/<%= portfolioUser.username %>/blog/<%= blog.slug %>"><%= blog.title %></a></h2>
          <p class="blog-card-excerpt"><%= blog.excerpt %></p>
          <div class="blog-card-tags">
            <% blog.tags_arr.slice(0, 3).forEach(tag => { %>
            <span class="tag"><%= tag %></span>
            <% }) %>
          </div>
          <a href="/<%= portfolioUser.username %>/blog/<%= blog.slug %>" class="blog-read-more">
            Read more
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </article>
      <% }) %>
    </div>
    <% } else { %>
    <div class="empty-state reveal">
      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
      <h3>No Blog Posts Yet</h3>
      <p>Articles and insights coming soon!</p>
    </div>
    <% } %>
  </div>
</section>

<%- include('../partials/tail') %>
