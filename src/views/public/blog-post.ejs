<%- include('../partials/head') %>

<article class="blog-post">
  <header class="blog-post-header">
    <div class="container">
      <a href="/<%= portfolioUser.username %>/blog" class="back-link reveal">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back to Blog
      </a>
      <div class="blog-post-meta reveal">
        <time datetime="<%= blog.created_at %>"><%= new Date(blog.created_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></time>
        <span class="meta-dot">·</span>
        <span><%= blog.reading_time %> min read</span>
      </div>
      <h1 class="blog-post-title reveal"><%= blog.title %></h1>
      <div class="blog-post-tags reveal">
        <% blog.tags_arr.forEach(tag => { %>
        <span class="tag"><%= tag %></span>
        <% }) %>
      </div>
    </div>
  </header>

  <% if (blog.cover_image) { %>
  <div class="blog-post-cover reveal">
    <div class="container">
      <img src="<%= blog.cover_image %>" alt="<%= blog.title %>">
    </div>
  </div>
  <% } %>

  <div class="blog-post-body">
    <div class="container container--narrow">
      <div class="prose reveal">
        <%- blog.content_html %>
      </div>
    </div>
  </div>

  <footer class="blog-post-footer">
    <div class="container container--narrow">
      <div class="share-section reveal">
        <span class="share-label">Share this article</span>
        <div class="share-links">
          <a href="https://twitter.com/intent/tweet?text=<%= encodeURIComponent(blog.title) %>" target="_blank" rel="noopener" class="share-btn" aria-label="Share on Twitter">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://www.linkedin.com/sharing/share-offsite/?url=<%= encodeURIComponent('') %>" target="_blank" rel="noopener" class="share-btn" aria-label="Share on LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </footer>
</article>

<%- include('../partials/tail') %>
